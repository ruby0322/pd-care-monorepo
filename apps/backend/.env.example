APP_NAME=pd-exit-site-inference-api
APP_ENV=production
LOG_LEVEL=INFO

# Docker Compose note:
# - The root compose file injects backend vars directly and supports optional
#   `PDCARE_*` overrides from your shell (for example PDCARE_DATABASE_URL).
# - This file is still the source of truth for local backend development when
#   copied to `.env` and sourced in apps/backend.
# Use a strong password in local/production environments.
DATABASE_URL=postgresql+psycopg://postgres:pdcare-local-dev-change-me@postgres:5432/pd_care
S3_ENDPOINT_URL=http://seaweedfs-s3:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=seaweed-access
S3_SECRET_KEY=seaweed-secret
S3_BUCKET_NAME=pd-care-private
IMAGE_ACCESS_TOKEN_SECRET=replace-with-strong-secret
IMAGE_ACCESS_TOKEN_TTL_SECONDS=300
AUTH_TOKEN_SECRET=replace-with-strong-auth-secret
AUTH_TOKEN_TTL_SECONDS=28800
# Comma-separated LINE User IDs stored as liff_identities.line_user_id (same as id_token "sub"
# / LIFF SDK getProfile().userId — usually starts with U). This is NOT the LIFF Endpoint ID shown
# in LINE Developers next to NEXT_PUBLIC_LIFF_ID (e.g. 1657724367-xxxx).
PILOT_ADMIN_IDENTITY_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: comma-separated LINE User IDs for staff role pilot accounts (same rules as admins).
PILOT_STAFF_IDENTITY_IDS=
LINE_VERIFY_MODE=line
LINE_CHANNEL_ID=
LINE_VERIFY_ENDPOINT=https://api.line.me/oauth2/v2.1/verify
LINE_VERIFY_TIMEOUT_SECONDS=5

MODEL_URL=https://huggingface.co/ruby0322/pd-exit-site-classification/resolve/main/model_e41_production_best.pt
# Compose/Docker: use /models. Local dev: use e.g. MODEL_CACHE_DIR=$HOME/.cache/pd-care (needs bash expand if sourcing .env).
MODEL_PATH=/models/model_e41_production_best.pt
MODEL_CACHE_DIR=/models
MODEL_TIMEOUT_SECONDS=300

DEVICE=auto
WORKERS=1

IMAGE_SIZE=384
INFECTION_CLASS_INDEX=4
CLASS_NAMES=class_0,class_1,class_2,class_3,class_4
THRESHOLD=0.5
MAX_UPLOAD_MB=10
ACCEPTED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/bmp,image/tiff

# Fallback settings used only if the checkpoint must be reconstructed from a state_dict.
MODEL_BACKBONE=mobilenet_v3_large
MODEL_ARCH=baseline
TRANSFER_DROPOUT=0.4
EVAL_HFLIP_TTA=false

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://1910-140-112-106-204.ngrok-free.app
# Quote value if you source .env with bash (parentheses in regex are shell syntax otherwise).
# Includes localhost / 127.0.0.1 with any port for dev tools; tighten in production if needed.
CORS_ALLOWED_ORIGIN_REGEX='^https?://localhost(?::\d+)?$|^https?://127\.0\.0\.1(?::\d+)?$|^https?://(?:\d{1,3}\.){3}\d{1,3}:3000$'

