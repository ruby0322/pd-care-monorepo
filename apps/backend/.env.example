APP_NAME=pd-exit-site-inference-api
APP_ENV=production
LOG_LEVEL=INFO

MODEL_URL=https://huggingface.co/ruby0322/pd-exit-site-classification/resolve/main/model_e41_production_best.pt
MODEL_PATH=/models/model_e41_production_best.pt
MODEL_CACHE_DIR=/models
MODEL_TIMEOUT_SECONDS=300

DEVICE=auto
WORKERS=1

IMAGE_SIZE=384
INFECTION_CLASS_INDEX=4
CLASS_NAMES=class_0,class_1,class_2,class_3,class_4
THRESHOLD=0.5
MAX_UPLOAD_MB=10
ACCEPTED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/bmp,image/tiff

# Fallback settings used only if the checkpoint must be reconstructed from a state_dict.
MODEL_BACKBONE=mobilenet_v3_large
MODEL_ARCH=baseline
TRANSFER_DROPOUT=0.4
EVAL_HFLIP_TTA=false

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://1910-140-112-106-204.ngrok-free.app
CORS_ALLOWED_ORIGIN_REGEX=^https?://(?:\d{1,3}\.){3}\d{1,3}:3000$

