# Local verification without LINE: copy to .env.local (gitignored, overrides .env) and pair with
# apps/backend/.env.stub.example (LINE_VERIFY_MODE=stub). See docs/ops/local-dev-without-line.md.
#
# Leaving NEXT_PUBLIC_LIFF_ID unset here (do not copy it from .env.example) enables the dev bypass
# in apps/frontend/lib/auth/liff.ts, which sends `stub:<line_user_id>` id tokens instead of real
# LINE ones.
# Use same-origin /api proxy (works from localhost and network IP). Pair with
# BACKEND_INTERNAL_URL=http://127.0.0.1:8000 in this file. See docs/ops/local-dev-without-line.md.
NEXT_PUBLIC_API_BASE_URL=/api
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Pick one dev persona seeded by `npm run seed:dev-personas` (see docs/ops/local-dev-without-line.md
# for the full table). Leave unset to exercise the "brand new user" flow (no liff_identities row).
NEXT_PUBLIC_DEV_LINE_USER_ID=U_DEV_ADMIN
NEXT_PUBLIC_DEV_DISPLAY_NAME=Dev Tester
