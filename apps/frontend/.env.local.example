# Local verification without LINE: copy to .env.local (gitignored, overrides .env).
# Pair with apps/backend/.env.local.example (LINE_VERIFY_MODE=stub).
# See docs/ops/local-dev-without-line.md.
#
# Leave NEXT_PUBLIC_LIFF_ID unset (do not copy it from .env.example). That enables the
# dev bypass in apps/frontend/lib/auth/liff.ts (`stub:<line_user_id>` tokens) and
# unlocks http://localhost:3000/dev/personas.
#
# Same-origin /api proxy (works from localhost and LAN IP). Pair with BACKEND_INTERNAL_URL.
NEXT_PUBLIC_API_BASE_URL=/api
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Optional: non-default dev port (abbey remote dev uses 3010 via `npm run dev:abbey`).
# PORT=3010
#
# Optional default persona when you skip /dev/personas. Prefer picking a role at
# http://localhost:3000/dev/personas after `npm run seed:dev-personas`.
# NEXT_PUBLIC_DEV_LINE_USER_ID=U_DEV_ADMIN
# NEXT_PUBLIC_DEV_DISPLAY_NAME=Dev Tester
