PDCARE_POSTGRES_PASSWORD=pdcare-local-dev-change-me
PDCARE_DATABASE_URL=postgresql+psycopg://postgres:pdcare-local-dev-change-me@postgres:5432/pd_care
# Local-only default (recommended): 127.0.0.1:5432
# Controlled remote mode (exception): 0.0.0.0:5432 + firewall + PDCARE_POSTGRES_HBA_FILE below
PDCARE_POSTGRES_PORT_BIND=127.0.0.1:5432
# Leave unset for default data-dir pg_hba.conf. Set this only for controlled remote mode:
# PDCARE_POSTGRES_HBA_FILE=/etc/pd-care/postgres/pg_hba.remote.conf
