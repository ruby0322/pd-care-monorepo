apiVersion: v1
kind: Secret
metadata:
  name: pd-care-secrets
type: Opaque
stringData:
  # Copy to secret.yaml (gitignored), replace placeholders, then apply before the overlay.
  # kubectl apply -f k8s/overlays/prod/secret.yaml -n pd-care-prod
  PDCARE_POSTGRES_PASSWORD: "change-me-prod-postgres"
  DATABASE_URL: "postgresql+psycopg://postgres:change-me-prod-postgres@postgres:5432/pd_care"
  S3_ACCESS_KEY: "change-me-prod-s3-access"
  S3_SECRET_KEY: "change-me-prod-s3-secret"
  IMAGE_ACCESS_TOKEN_SECRET: "change-me-prod-image-token"
  AUTH_TOKEN_SECRET: "change-me-prod-auth-token"
  HF_TOKEN: ""
